# Backend environment example for Pawber API
# Copy this to `backend/.env` and fill with your real values before running the server

# Server
PORT=4000
NODE_ENV=development

# Supabase - replace with your project's values
# SUPABASE_URL should be like: https://<project-ref>.supabase.co
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# If you want to force the in-memory mock (for local dev/testing), set true.
# When using a real Supabase project, remove or set to false.
FORCE_SUPABASE_MOCK=false

# Optional: If you want the backend to probe remote Supabase, leave FORCE_SUPABASE_MOCK unset.

# NOTES:
# 1) After filling these values, run the migration SQL from:
#    backend/src/db/migration.sql
#    Paste it into your Supabase project's SQL Editor and execute.
# 2) Then start the dev server:
#    cd backend
#    npm run dev
# PetCare Backend Environment Variables

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=your-jwt-secret-change-this-in-production

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
