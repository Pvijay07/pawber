{
    "name": "pawber-backend",
    "version": "1.0.0",
    "description": "Pawber Marketplace API - Express + TypeScript + Supabase",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "dev:legacy": "tsx watch src/index.ts",
        "build": "node -e \"const fs=require('fs');if(fs.existsSync('dist')){fs.rmSync('dist',{recursive:true,force:true})}\" && tsc && node -e \"const fs=require('fs');const p=require('path');fs.mkdirSync(p.join('dist','db'),{recursive:true});const src='src/db';if(fs.existsSync(src)){fs.readdirSync(src).filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(p.join(src,f),p.join('dist','db',f)))}\"",
        "start": "node dist/server.js",
        "postinstall": "npm run build",
        "migrate": "tsx src/db/migrate.ts",
        "seed:packages": "tsx scripts/seed_packages.ts"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.45.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "express-rate-limit": "^7.4.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "pg": "^8.20.0",
        "razorpay": "^2.9.4",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "zod": "^3.23.8",
        "express-list-endpoints": "^7.1.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/node": "^22.5.0",
        "@types/pg": "^8.20.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "express-list-endpoints": "^7.1.1",
        "tsx": "^4.19.0",
        "typescript": "^5.5.4"
    }
}
